# Copy this file to assets/.env and fill in values.
# The app loads env from assets/.env (see lib/main.dart).

#  JWT (HS256) — access key as iss, secret signs the token
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# --- API ---

# Base URL without trailing slash (default https://api.kling.ai)
# Example: https://api-singapore.klingai.com
KLING_API_BASE_URL=

# model_name for POST /v1/images/generations (default kling-v2-1)
KLING_MODEL_NAME=
